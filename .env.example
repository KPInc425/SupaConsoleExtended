# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-make-this-random-and-secure"
NEXTAUTH_URL="http://localhost:3000"

# SMTP Configuration for Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Supabase Core Repository URL (to be cloned during initialization)
SUPABASE_CORE_REPO_URL="https://github.com/supabase/supabase"

# Application Configuration
APP_NAME="Supabase Console Dashboard"
APP_URL="http://localhost:3000"

# Docker-compose / Production variables
# The docker compose stack requires POSTGRES_PASSWORD to be set. Copy this
# file to `.env` and replace the placeholders with secure values before
# running `docker compose up`.
POSTGRES_USER=supaconsole
# REQUIRED: set a strong password before starting the containers
POSTGRES_PASSWORD=postgres
POSTGRES_DB=supaconsole

# App runtime
APP_PORT=3000

# NEXTAUTH secret used by the app for session encryption
NEXTAUTH_SECRET=replace_with_a_long_random_string

# Optional: OAuth/OIDC central auth (leave blank if not using)
OAUTH_ISSUER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Optional SMTP settings
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@supaconsole.local