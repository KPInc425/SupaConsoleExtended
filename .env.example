# Development environment for SupaConsole.
# The control plane metadata database defaults to a local SQLite file for portability.

DATABASE_URL="file:./dev.db"

# Application Configuration
APP_NAME="SupaConsole"
APP_URL="http://localhost:3000"

# SMTP Configuration for email flows (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Control plane runtime defaults
APP_PORT=3000

# Optional OAuth/OIDC integration
OAUTH_ISSUER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=
# Optional Phase 4 operational config layering
# System defaults -> shared topology -> per-project config -> secret references
SUPACONSOLE_TOPOLOGY_SETTINGS_FILE=.supaconsole/shared-topology.json
SUPACONSOLE_SECRET_FILE=.supaconsole/secrets.json
SUPACONSOLE_BACKUP_DIR=.supaconsole/backups
SUPACONSOLE_LIFECYCLE_LOG_FILE=.supaconsole/logs/lifecycle.jsonl

# Optional process-env secret references for project env vars
# Example: set a project key to { valueSource: "indirect", secretReference: "env:SUPACONSOLE_PROJECT_JWT_SECRET" }
SUPACONSOLE_PROJECT_JWT_SECRET=

# Managed project runtime env vars are generated automatically per project.