# ==============================================
# PHASE 4 CONFIG / SECRETS / OPERATIONS
# ==============================================
# These defaults define the inspectable operational surfaces written by SupaConsole.
SUPACONSOLE_TOPOLOGY_SETTINGS_FILE=.supaconsole/shared-topology.json
SUPACONSOLE_SECRET_FILE=.supaconsole/secrets.json
SUPACONSOLE_BACKUP_DIR=.supaconsole/backups
SUPACONSOLE_LIFECYCLE_LOG_FILE=.supaconsole/logs/lifecycle.jsonl

# Optional process-env secrets that per-project config can reference indirectly.
# Example project env payload:
# { "JWT_SECRET": { "valueSource": "indirect", "secretReference": "env:SUPACONSOLE_PROJECT_JWT_SECRET" } }
SUPACONSOLE_PROJECT_JWT_SECRET=
# SupaConsole production-oriented environment example.
# Copy this file to .env and fill in the values that match your deployment.
#
# This file documents the production deployment blueprint used by:
# 1. docker-compose.yml for the basic control-plane stack, and
# 2. deploy/docker-compose.production.yml for the internet-facing stack with NGINX.

# ==============================================
# CONTROL-PLANE DATABASE CONFIGURATION
# ==============================================
# Persist this SQLite file on durable storage for the SupaConsole app itself.
DATABASE_URL=file:/app/.supaconsole/control-plane.db

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
APP_NAME=SupaConsole
APP_URL=https://supaconsole.example.com
APP_PORT=3000

# Reverse proxy listener for deploy/docker-compose.production.yml.
NGINX_HTTP_PORT=80
NGINX_SERVER_NAME=supaconsole.example.com

# ==============================================
# EMAIL CONFIGURATION
# ==============================================
# These are the variables read by src/lib/email.ts.
# Leave blank if you do not want SMTP-backed email flows.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ==============================================
# OPTIONAL OAUTH / OIDC VALUES
# ==============================================
# These are not consumed by the current local-auth baseline unless you wire custom deployment behavior around them.
OAUTH_ISSUER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=

# ==============================================
# OPTIONAL AUTHENTIK TEMPLATE VALUES
# ==============================================
# The docker-compose.yml file carries commented Authentik blocks as deployment-template reference only.
# AUTHENTIK_SECRET_KEY=changeme_generate_random_secret_here
# AUTHENTIK_DB_USER=authentik
# AUTHENTIK_DB_PASSWORD=changeme_secure_password_here
# AUTHENTIK_DB_NAME=authentik
# AUTHENTIK_PORT_HTTP=9000
# AUTHENTIK_PORT_HTTPS=9443

# ==============================================
# OPTIONAL SHARED-TOPOLOGY SETTINGS
# ==============================================
# These target the shared Postgres or shared service layer used by managed project modes.
SUPACONSOLE_SHARED_TOPOLOGY_NAME=production-shared
SUPACONSOLE_DEFAULT_INSTANCE_MODE=full_stack_isolated
SUPACONSOLE_SHARED_PG_ADMIN_URL=
SUPACONSOLE_SHARED_PG_SCHEMA_DATABASE=
SUPACONSOLE_SHARED_PG_ADMIN_DATABASE=
SUPACONSOLE_SHARED_SERVICE_API_URL=
SUPACONSOLE_SHARED_SERVICE_STUDIO_URL=
SUPACONSOLE_SHARED_SERVICE_DATABASE_URL=
SUPACONSOLE_SHARED_SERVICE_AUTH_URL=
SUPACONSOLE_SHARED_SERVICE_STORAGE_URL=
SUPACONSOLE_SHARED_SERVICE_REALTIME_URL=
SUPACONSOLE_SHARED_SERVICE_MAIL_URL=

# ==============================================
# DOCKER CONFIGURATION
# ==============================================
# Required when the control plane manages full-stack project runtimes through Docker.
DOCKER_SOCKET_PATH=/var/run/docker.sock
