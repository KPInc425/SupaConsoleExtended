# SupaConsole Production Environment Variables
# Copy this file to .env and fill in the values

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
POSTGRES_USER=supaconsole
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=supaconsole

# SQLite to PostgreSQL connection string
DATABASE_URL=postgresql://supaconsole:changeme_secure_password_here@db:5432/supaconsole

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
# Public URL where SupaConsole is accessible
APP_URL=http://localhost:3000
APP_PORT=3000

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=changeme_generate_random_secret_here

# ==============================================
# OAUTH/OIDC CONFIGURATION (Optional)
# Leave empty to use local authentication
# Fill in to use centralized auth (Authentik, Keycloak, etc.)
# ==============================================
# OAUTH_ISSUER=https://auth.yourdomain.com/application/o/supaconsole/
# OAUTH_CLIENT_ID=your_client_id
# OAUTH_CLIENT_SECRET=your_client_secret
# OAUTH_AUTHORIZATION_URL=https://auth.yourdomain.com/application/o/authorize/
# OAUTH_TOKEN_URL=https://auth.yourdomain.com/application/o/token/
# OAUTH_USERINFO_URL=https://auth.yourdomain.com/application/o/userinfo/

# ==============================================
# AUTHENTIK CONFIGURATION (Optional)
# Uncomment if deploying Authentik for centralized auth
# ==============================================
# AUTHENTIK_SECRET_KEY=changeme_generate_random_secret_here
# AUTHENTIK_DB_USER=authentik
# AUTHENTIK_DB_PASSWORD=changeme_secure_password_here
# AUTHENTIK_DB_NAME=authentik
# AUTHENTIK_PORT_HTTP=9000
# AUTHENTIK_PORT_HTTPS=9443

# ==============================================
# EMAIL CONFIGURATION (Optional)
# For password resets and notifications
# ==============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@supaconsole.local

# ==============================================
# DOCKER CONFIGURATION
# ==============================================
# Docker socket path (usually /var/run/docker.sock on Linux)
DOCKER_SOCKET_PATH=/var/run/docker.sock
